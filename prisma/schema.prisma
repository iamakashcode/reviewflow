generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  name         String?
  email        String     @unique
  passwordHash String
  locations    Location[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Location {
  id                   String     @id @default(cuid())
  userId               String
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                 String
  slug                 String     @unique
  googleReviewUrl      String
  redirectThreshold    Int        @default(4)
  feedbacks            Feedback[]
  reviewOpens          ReviewOpen[]
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

model ReviewOpen {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  rating     Int
  createdAt  DateTime @default(now())
}

model Feedback {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name       String?
  message    String
  rating     Int
  createdAt  DateTime @default(now())
}
